{
  "expo": {
    "name": "EconoFlow",
    "slug": "econoflow-mobile",
    "owner": "econoflow",
    "scheme": "econoflow",
    "newArchEnabled": false,
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon-512x512.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#061e33"
    },
    "android": {
      "package": "pt.econoflow.mobile",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-512x512.png",
        "backgroundColor": "#0f76a8"
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#061e33"
      }
    },
    "ios": {
      "bundleIdentifier": "pt.econoflow.mobile",
      "buildNumber": "2"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#061e33",
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "imageWidth": 150
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2265ef61-8266-496c-b5ff-3171b3078e88"
      }
    }
  }
}
