{
  "name": ".NET 8 + Angular 21 (pnpm)",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-8.0",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "pnpmVersion": "latest",
      "nodeGypDependencies": true
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "Angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "dotnet.defaultSolution": "**/*.sln"
      }
    }
  },

  "forwardPorts": [4200, 5000, 5001],
  "portsAttributes": {
    "4200": { "label": "Angular dev server" },
    "5000": { "label": "ASP.NET HTTP" },
    "5001": { "label": "ASP.NET HTTPS" }
  },

  "mounts": [
    "source=nuget-cache,target=/home/vscode/.nuget/packages,type=volume",
    "source=pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume"
  ],

  "remoteEnv": {
    "NUGET_PACKAGES": "/home/vscode/.nuget/packages"
  },

  "postCreateCommand": "bash -lc 'corepack enable || true; pnpm config set store-dir /home/vscode/.local/share/pnpm/store || true'",

  "remoteUser": "vscode"
}
